#version 330 core
// Delta-shaped fan shears with airy top-end motion.
in vec2 tc; out vec4 color;
uniform sampler2D samp,samp1,samp2,samp3,samp4,samp5,samp6,samp7,samp8;
uniform sampler1D spectrum0,spectrum1,spectrum2,spectrum3,spectrum4,spectrum5,spectrum6,spectrum7;
uniform float time_f,amp_peak,amp_smooth; uniform vec2 iResolution;
const float TAU=6.28318530718;
vec3 acid(float t){return 0.5+0.5*cos(TAU*(vec3(0.56,0.88,1.0)*t+vec3(0.18,0.34,0.46)));}
vec4 cacheHist(int i, vec2 uv){if(i==0)return texture(samp1,uv);if(i==1)return texture(samp2,uv);if(i==2)return texture(samp3,uv);if(i==3)return texture(samp4,uv);if(i==4)return texture(samp5,uv);if(i==5)return texture(samp6,uv);if(i==6)return texture(samp7,uv);return texture(samp8,uv);} 
float specHist(int i,float f){if(i==0)return texture(spectrum0,f).r;if(i==1)return texture(spectrum1,f).r;if(i==2)return texture(spectrum2,f).r;if(i==3)return texture(spectrum3,f).r;if(i==4)return texture(spectrum4,f).r;if(i==5)return texture(spectrum5,f).r;if(i==6)return texture(spectrum6,f).r;return texture(spectrum7,f).r;}
vec2 shearField(vec2 uv,float bass,float mid,float treble,float air,vec3 oldest,float layer){float fan=abs(uv.x)*1.6+uv.y*0.4; vec2 dir=vec2(sign(uv.x)*(0.3+fan),-fan); dir+=vec2(sin(uv.y*18.0+time_f*1.8+layer),cos(uv.x*8.0-time_f*1.2-layer))*0.4; dir+=vec2(oldest.b-oldest.r,oldest.g-oldest.b)*0.6; return dir*(0.011+air*0.030+treble*0.015);} 
void main(){float aspect=iResolution.x/iResolution.y; vec2 uv=(tc-0.5)*vec2(aspect,1.0); float bass=texture(spectrum0,0.03).r,mid=texture(spectrum0,0.25).r,treble=texture(spectrum0,0.64).r,air=texture(spectrum0,0.93).r; float hist=0.0; for(int i=0;i<8;i++) hist+=specHist(i,0.93); hist/=8.0; vec3 oldest=texture(samp8,tc+vec2(cos(time_f*0.15+uv.y*7.0),sin(time_f*0.17+uv.x*4.0))*(0.012+hist*0.034)).rgb; vec3 live=texture(samp,tc+shearField(uv,bass,mid,treble,air,oldest,0.0)).rgb*acid(time_f*0.05+uv.y*0.28+air); vec3 accum=live; float wsum=1.0; for(int i=0;i<8;i++){float layer=float(i+1); float hB=specHist(i,0.03),hM=specHist(i,0.25),hT=specHist(i,0.64),hA=specHist(i,0.93); vec3 cached=cacheHist(i,tc+shearField(uv,hB,hM,hT,hA,oldest,layer)).rgb; float w=pow(0.82,layer)*(1.0+hA*1.25); accum+=cached*acid(layer*0.08+hA*0.8+time_f*0.02)*w; wsum+=w;} accum/=wsum; float fanGlow=smoothstep(0.45,1.0,abs(sin(abs(uv.x)*20.0+uv.y*12.0-time_f*1.8+hist*8.0))); accum+=acid(time_f*0.03+uv.x*0.18)*fanGlow*(0.05+amp_smooth*0.18); color=vec4(clamp(accum,0.0,1.0),1.0);} 
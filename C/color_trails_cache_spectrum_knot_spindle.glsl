#version 330 core
// Spindle-like knots spinning inward through layered history.
in vec2 tc; out vec4 color;
uniform sampler2D samp,samp1,samp2,samp3,samp4,samp5,samp6,samp7,samp8;
uniform sampler1D spectrum0,spectrum1,spectrum2,spectrum3,spectrum4,spectrum5,spectrum6,spectrum7;
uniform float time_f,amp_peak,amp_smooth; uniform vec2 iResolution;
const float TAU=6.28318530718;
vec3 acid(float t){return 0.5+0.5*cos(TAU*(vec3(0.82,0.74,1.0)*t+vec3(0.10,0.19,0.37)));}
vec4 cacheHist(int i, vec2 uv){if(i==0)return texture(samp1,uv);if(i==1)return texture(samp2,uv);if(i==2)return texture(samp3,uv);if(i==3)return texture(samp4,uv);if(i==4)return texture(samp5,uv);if(i==5)return texture(samp6,uv);if(i==6)return texture(samp7,uv);return texture(samp8,uv);} 
float specHist(int i,float f){if(i==0)return texture(spectrum0,f).r;if(i==1)return texture(spectrum1,f).r;if(i==2)return texture(spectrum2,f).r;if(i==3)return texture(spectrum3,f).r;if(i==4)return texture(spectrum4,f).r;if(i==5)return texture(spectrum5,f).r;if(i==6)return texture(spectrum6,f).r;return texture(spectrum7,f).r;}
vec2 knotField(vec2 uv,float bass,float mid,float treble,float air,vec3 oldest,float layer){float r=length(uv)+0.001; float a=atan(uv.y,uv.x); vec2 dir=vec2(cos(a*3.0-r*(6.0+treble*8.0)-time_f*(1.0+mid*1.4)-layer),sin(a*2.0+r*(5.0+bass*6.0)+time_f*(0.9+air*1.2)+layer)); dir+=vec2(oldest.g-oldest.b,oldest.r-oldest.g)*0.75; return dir*(0.010+mid*0.024+treble*0.015)-uv*(0.003+bass*0.014);} 
void main(){float aspect=iResolution.x/iResolution.y; vec2 uv=(tc-0.5)*vec2(aspect,1.0); float bass=texture(spectrum0,0.02).r,mid=texture(spectrum0,0.20).r,treble=texture(spectrum0,0.56).r,air=texture(spectrum0,0.84).r; float hist=0.0; for(int i=0;i<8;i++) hist+=specHist(i,0.56); hist/=8.0; vec3 oldest=texture(samp8,tc+vec2(sin(time_f*0.22+uv.y*6.0),cos(time_f*0.24+uv.x*6.0))*(0.011+hist*0.027)).rgb; vec3 live=texture(samp,tc+knotField(uv,bass,mid,treble,air,oldest,0.0)).rgb*acid(time_f*0.06+length(uv)*0.45+treble); vec3 accum=live; float wsum=1.0; for(int i=0;i<8;i++){float layer=float(i+1); float hB=specHist(i,0.02),hM=specHist(i,0.20),hT=specHist(i,0.56),hA=specHist(i,0.84); vec3 cached=cacheHist(i,tc+knotField(uv,hB,hM,hT,hA,oldest,layer)).rgb; float w=pow(0.80,layer)*(1.0+hT*1.1+hB*0.4); accum+=cached*acid(layer*0.10+hT*0.7+oldest.b*0.2)*w; wsum+=w;} accum/=wsum; float spindle=smoothstep(0.45,1.0,abs(cos(length(uv)*24.0-time_f*1.7+hist*9.0))); accum+=acid(time_f*0.03+uv.y*0.18)*spindle*(0.05+amp_smooth*0.17); color=vec4(clamp(accum,0.0,1.0),1.0);} 
#version 330 core
// Gyroscopic trail orbits with asymmetric spin and bass-heavy precession.
in vec2 tc; out vec4 color;
uniform sampler2D samp,samp1,samp2,samp3,samp4,samp5,samp6,samp7,samp8;
uniform sampler1D spectrum0,spectrum1,spectrum2,spectrum3,spectrum4,spectrum5,spectrum6,spectrum7;
uniform float time_f,amp_peak,amp_smooth; uniform vec2 iResolution;
const float TAU=6.28318530718;
vec3 acid(float t){return 0.5+0.5*cos(TAU*(vec3(0.9,0.7,0.85)*t+vec3(0.09,0.22,0.33)));}
vec4 cacheHist(int i, vec2 uv){if(i==0)return texture(samp1,uv);if(i==1)return texture(samp2,uv);if(i==2)return texture(samp3,uv);if(i==3)return texture(samp4,uv);if(i==4)return texture(samp5,uv);if(i==5)return texture(samp6,uv);if(i==6)return texture(samp7,uv);return texture(samp8,uv);} 
float specHist(int i,float f){if(i==0)return texture(spectrum0,f).r;if(i==1)return texture(spectrum1,f).r;if(i==2)return texture(spectrum2,f).r;if(i==3)return texture(spectrum3,f).r;if(i==4)return texture(spectrum4,f).r;if(i==5)return texture(spectrum5,f).r;if(i==6)return texture(spectrum6,f).r;return texture(spectrum7,f).r;}
vec2 orbitField(vec2 uv,float bass,float mid,float treble,float air,vec3 oldest,float layer){float a=atan(uv.y,uv.x); float r=length(uv)+0.001; float precess=sin(time_f*(0.7+bass*2.0)+layer*0.9); vec2 dir=vec2(cos(a*(2.0+precess)+time_f*(1.3+mid*1.8)-r*(8.0+treble*12.0)),sin(a*(3.0-precess)-time_f*(1.6+air*2.0)+r*(6.0+bass*11.0))); dir+=vec2(oldest.r-oldest.b,oldest.g-0.5)*0.85; return dir*(0.011+mid*0.026+treble*0.016);} 
void main(){float aspect=iResolution.x/iResolution.y; vec2 uv=(tc-0.5)*vec2(aspect,1.0); float bass=texture(spectrum0,0.02).r,mid=texture(spectrum0,0.18).r,treble=texture(spectrum0,0.54).r,air=texture(spectrum0,0.82).r; float hist=0.0; for(int i=0;i<8;i++) hist+=specHist(i,0.02); hist/=8.0; vec3 oldest=texture(samp8,tc+vec2(cos(time_f*0.32+uv.y*6.0+hist*9.0),sin(time_f*0.25-uv.x*4.0))*(0.012+hist*0.030)).rgb; vec3 live=texture(samp,tc+orbitField(uv,bass,mid,treble,air,oldest,0.0)).rgb; live=mix(live,live.rbg,0.18+treble*0.22)*acid(time_f*0.08+length(uv)*0.6+bass); vec3 accum=live; float wsum=1.0; for(int i=0;i<8;i++){float layer=float(i+1); float hB=specHist(i,0.02),hM=specHist(i,0.18),hT=specHist(i,0.54),hA=specHist(i,0.82); vec3 cached=cacheHist(i,tc+orbitField(uv,hB,hM,hT,hA,oldest,layer)).rgb; float w=pow(0.79,layer)*(1.0+hB*1.4+hT*0.5); accum+=cached*acid(layer*0.13+hM*0.7+time_f*0.03)*w; wsum+=w;} accum/=wsum; float spark=smoothstep(0.45,1.0,abs(cos(atan(uv.y,uv.x)*4.0+time_f*2.1+hist*7.0))); accum+=acid(uv.y*0.2+time_f*0.04)*spark*(0.07+amp_smooth*0.19); color=vec4(clamp(accum,0.0,1.0),1.0);} 